---
import { getCategoryLabel, duongDanAnhBia } from '../lib/categories';

interface Props {
	id: string;
	category: string;
	title: string;
	date: Date;
	source: string;
	summary: string;
	cover?: string;
}

const { id, category, title, date, source, summary, cover } = Astro.props;
const anhBia = duongDanAnhBia(category, id, cover);
---

<a class="card" href={`/${category}/${id}/`}>
	<div class="card-cover">
		<img src={anhBia} alt="" loading="lazy" />
	</div>
	<div class="card-body">
		<span class={`badge ${category}`}>{getCategoryLabel(category)}</span>
		<h2>{title}</h2>
		<p class="summary">{summary}</p>
		<div class="meta">
			<time datetime={date.toISOString()}>{date.toLocaleDateString('vi-VN')}</time>
			<span> · {source}</span>
		</div>
	</div>
</a>
