---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Không tìm thấy trang">
	<div class="not-found">
		<h1>404 — Không tìm thấy trang</h1>
		<p>Trang bạn tìm không tồn tại hoặc đã được di chuyển.</p>
		<a class="back" href="/">← Về trang chủ</a>
	</div>
</BaseLayout>

<style>
	.not-found {
		text-align: center;
		padding: 4rem 1rem;
	}

	.not-found .back {
		display: inline-block;
		margin-top: 1rem;
	}
</style>
