---
import { getCollection, type GetStaticPathsOptions } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Pagination from '../../components/Pagination.astro';
import { CATEGORIES, getCategoryLabel, type CategorySlug } from '../../lib/categories';

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
	const paths = [];
	for (const cat of CATEGORIES) {
		const articles = (await getCollection(cat.slug)).sort(
			(a, b) => b.data.date.valueOf() - a.data.date.valueOf()
		);
		paths.push(
			...paginate(articles, {
				params: { category: cat.slug },
				pageSize: 9,
			})
		);
	}
	return paths;
}

const { category } = Astro.params as { category: CategorySlug };
const { page } = Astro.props;
---

<BaseLayout title={getCategoryLabel(category)}>
	<h1>{getCategoryLabel(category)}</h1>
	{
		page.data.length === 0 ? (
			<p>Chưa có bài viết trong mục này.</p>
		) : (
			<div class="grid">
				{page.data.map((article) => (
					<ArticleCard
						id={article.id}
						category={category}
						title={article.data.title}
						date={article.data.date}
						source={article.data.source}
						summary={article.data.summary}
						cover={article.data.cover}
					/>
				))}
			</div>
		)
	}
	<Pagination page={page} />
</BaseLayout>
