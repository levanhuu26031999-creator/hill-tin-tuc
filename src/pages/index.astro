---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import PromoBanner from '../components/PromoBanner.astro';
import { CATEGORIES, getCategoryLabel, duongDanAnhBia } from '../lib/categories';
import { getAllArticles } from '../lib/tags';

const allArticles = (await getAllArticles()).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const [featured, ...rest] = allArticles;
const tagline = CATEGORIES.map((cat) => cat.label).join(' · ');
---

<BaseLayout title="Hill Tin Tức">
	<h1>Hill Tin Tức</h1>
	<p class="tagline">Tin tức tổng hợp: {tagline}</p>
	{
		!featured ? (
			<p>Chưa có bài viết.</p>
		) : (
			<>
				<a class="featured" href={`/${featured.category}/${featured.id}/`}>
					<div class="featured-cover">
						<img
							src={duongDanAnhBia(featured.category, featured.id, featured.data.cover)}
							alt=""
							width="1200"
							height="630"
						/>
					</div>
					<div class="featured-body">
						<span class={`badge ${featured.category}`}>{getCategoryLabel(featured.category)}</span>
						<h2>{featured.data.title}</h2>
						<p class="summary">{featured.data.summary}</p>
						<div class="meta">
							<time datetime={featured.data.date.toISOString()}>
								{featured.data.date.toLocaleDateString('vi-VN')}
							</time>
							<span> · {featured.data.source}</span>
						</div>
						<span class="read-more">Đọc tiếp →</span>
					</div>
				</a>

				<PromoBanner />

				{rest.length > 0 && (
					<>
						<h2 class="section-heading">Mới nhất</h2>
						<div class="grid">
							{rest.map((article) => (
								<ArticleCard
									id={article.id}
									category={article.category}
									title={article.data.title}
									date={article.data.date}
									source={article.data.source}
									summary={article.data.summary}
									cover={article.data.cover}
								/>
							))}
						</div>
					</>
				)}
			</>
		)
	}
</BaseLayout>
